[includeIf "gitdir:~/Work/**"]
  path = ~/.local/share/git/work.gitconfig

[include]
  path = ~/.local/share/git/personal.gitconfig

[include]
  path = ./delta.gitconfig

[init]
  defaultBranch = main

[hub]
  protocol = ssh

[core]
  autocrlf = input
  filemode = false

[push]
  autoSetupRemote = true
