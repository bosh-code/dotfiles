.DS_Store

# Ignore all children of .config by default
.config/*

# Re-include select dirs
!.config/zsh/
!git/
!.config/zed/
!.config/ghostty/
!.config/pnpm/

# Ignore compiled zsh files
.zsh_plugins.zsh
*.zwc
*.zwc.old
.zcompdump

# Ignore generated files
.config/zsh/.zsh_history
.config/zsh/.zsh_sessions/
.config/zsh/completions/

# Zed
.config/zed/prompts
.config/zed/themes

# Ignore 1password config file SSH known hosts files
# The 1password file just contains the socket stuff and is generated.
.ssh/1password.conf
.ssh/known_hosts
.ssh/known_hosts.old
