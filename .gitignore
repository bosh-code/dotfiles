.DS_Store

# Ignore all children of .config by default
.config/*

# Re-include select dirs
!.config/zsh/
!git/
!.config/zed/
!.config/ghostty/

# Ignore compiled zsh files
.zsh_plugins.zsh
*.zwc
*.zwc.old

# Ignore generated files
.config/zsh/.zsh_history
.config/zsh/.zsh_sessions/
.config/zsh/completions/

# Zed
.config/zed/prompts
.config/zed/themes
